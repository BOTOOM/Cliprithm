{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SilenCut",
  "version": "0.1.0",
  "identifier": "com.botom.silencut",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SilenCut — The Precision Darkroom",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://github.com https://api.github.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' asset: tauri: data:; media-src 'self' asset: tauri:; script-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$HOME/**",
          "$DOWNLOAD/**",
          "$DOCUMENT/**",
          "$DESKTOP/**",
          "$VIDEO/**",
          "$TEMP/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhGQkE1Qjc2MDgwMjdCRTUKUldUbGV3SUlkbHU2ajA1RHNzWTZnMEpwMi9HWm5vR2xFV2loZHoxV2xmN0RHVitwaXFNbzd2Q1UK",
      "endpoints": [
        "https://github.com/botom/silencut/releases/latest/download/latest.json"
      ]
    }
  }
}
