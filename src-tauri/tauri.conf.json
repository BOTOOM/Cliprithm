{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cliprithm",
  "version": "1.3.2",
  "identifier": "com.botom.cliprithm",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cliprithm",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://github.com https://api.github.com https://aur.archlinux.org http://127.0.0.1:*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' asset: tauri: data: https://avatars.githubusercontent.com; media-src 'self' asset: tauri: http://127.0.0.1:*; script-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$HOME/**",
          "$DOWNLOAD/**",
          "$DOCUMENT/**",
          "$DESKTOP/**",
          "$VIDEO/**",
          "$TEMP/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "appimage": {
      "exclude": [
        "libwebkit2gtk-4.1.so*",
        "libjavascriptcoregtk-4.1.so*",
        "libwayland-client.so*",
        "libwayland-egl.so*",
        "libwayland-server.so*",
        "libwayland-cursor.so*",
        "libepoxy.so*",
        "libEGL.so*",
        "libGL.so*",
        "libgbm.so*",
        "libgtk-3.so*",
        "libgdk-3.so*",
        "libpango-1.0.so*",
        "libpangocairo-1.0.so*",
        "libpangoft2-1.0.so*",
        "libcairo.so*",
        "libcairo-gobject.so*",
        "libgdk_pixbuf-2.0.so*",
        "libatk-1.0.so*",
        "libatk-bridge-2.0.so*",
        "libffi.so*",
        "libglapi.so*",
        "libGLX.so*",
        "libGLdispatch.so*"
      ]
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCQjAxRUQ0RjVENTREMDEKUldRQlRkWDExQjZ3SzNoVDk2YkkwTFZoYXdBUlgvbVpKMGpGdEFhdEZRNzRacXp4Y2dCdGxwTU8K",
      "endpoints": [
        "https://github.com/BOTOOM/Cliprithm/releases/latest/download/latest.json"
      ]
    }
  }
}
